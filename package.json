{
  "name": "json-rest-api",
  "version": "1.0.0",
  "description": "A simple, extensible RESTful JSON API library with schema validation and positioning",
  "main": "index.js",
  "type": "module",
  "keywords": [
    "rest",
    "json-api",
    "mysql",
    "schema",
    "validation"
  ],
  "author": "Tony Mobily",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mobily-enterprises/json-rest-api.git"
  },
  "scripts": {
    "test": "node tests/test-suite.js",
    "test:verbose": "node tests/test-suite.js --test-reporter spec",
    "test:tap": "node tests/test-suite.js --test-reporter tap",
    "test:mysql": "node tests/test-suite-mysql.js",
    "test:mysql:comprehensive": "node tests/test-mysql-comprehensive.js",
    "test:all": "npm test && npm run test:mysql"
  },
  "dependencies": {
    "circular-json-es6": "^2.0.2",
    "express": "^4.21.1",
    "mysql2": "^3.13.1",
    "semver": "^7.5.4",
    "thenby": "^1.3.4",
    "why-is-node-running": "^3.2.2"
  },
  "engines": {
    "node": ">=18"
  }
}
