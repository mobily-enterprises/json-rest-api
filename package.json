{
  "name": "json-rest-api",
  "version": "1.0.22",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:anyapi": "JSON_REST_API_STORAGE=anyapi node --test tests/*.test.js",
    "docs": "node scripts/run-docs.js",
    "sloc": "sloc --exclude \"(_site|node_modules|\\.git|vendor|docs)\" .",
    "slod": "cd docs;echo 'DOC LINES:'; cat `find . -iname \\*md | grep -v _site | grep -v vendor` | wc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobily-enterprises/jsonrestapi.git"
  },
  "author": "Tony Mobily",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/mobily-enterprises/jsonrestapi/issues"
  },
  "homepage": "https://mobily-enterprises.github.io/json-rest-api",
  "description": "REST API plugin for hooked-api with JSON:API compliance",
  "dependencies": {
    "hooked-api": "^1.0.24",
    "json-rest-schema": "^1.0.12",
    "semver": "^7.7.2"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "fractional-indexing": "^3.2.0",
    "knex": "^3.1.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fractional-indexing": {
      "optional": true
    },
    "knex": {
      "optional": true
    }
  },
  "devDependencies": {
    "better-sqlite3": "^11.10.0",
    "express": "^5.1.0",
    "fractional-indexing": "^3.2.0",
    "knex": "^3.1.0",
    "supertest": "^7.1.3",
    "eslint": "^9.37.0",
    "neostandard": "^0.12.2"
  }
}
