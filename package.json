{
  "name": "json-rest-api",
  "version": "1.0.0",
  "description": "A simple, extensible RESTful JSON API library with schema validation and positioning",
  "main": "index.js",
  "type": "module",
  "keywords": [
    "rest",
    "json-api",
    "mysql",
    "schema",
    "validation"
  ],
  "author": "Tony Mobily",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mobily-enterprises/json-rest-api.git"
  },
  "scripts": {
    "test": "node tests/test-all.js",
    "test:verbose": "node tests/test-all.js --test-reporter spec",
    "test:tap": "node tests/test-all.js --test-reporter tap",
    "test:mysql": "DB_TYPE=mysql node tests/test-all.js",
    "test:all-db": "npm test && npm run test:mysql",
    "test:ci": "npm run test:all-db",
    "test:http": "node tests/http/run-all-tests.js",
    "test:http:mysql": "DB_TYPE=mysql MYSQL_USER=root MYSQL_PASSWORD='' node tests/http/run-all-tests.js",
    "test:all": "npm test && npm run test:http",
    "test:core": "node tests/test-runner.js --group=core",
    "test:core-extra": "node tests/test-runner.js --group=core-extra",
    "test:protocols": "node tests/test-runner.js --group=protocols",
    "test:infrastructure": "node tests/test-runner.js --group=infrastructure",
    "test:enterprise": "node tests/test-runner.js --group=enterprise",
    "test:groups": "npm run test:core && npm run test:core-extra && npm run test:protocols && npm run test:infrastructure && npm run test:enterprise",
    "sync-docs": "node scripts/sync-docs-website.js",
    "docs:dev": "cd docs-website && npx http-server -p 8080",
    "build": "tsc",
    "build:watch": "tsc -w",
    "type-check": "tsc --noEmit",
    "prebuild": "npm run clean",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "migrate:create": "node bin/migrate.js create",
    "migrate:up": "node bin/migrate.js up",
    "migrate:down": "node bin/migrate.js down",
    "migrate:status": "node bin/migrate.js status",
    "migrate:reset": "node bin/migrate.js reset",
    "migrate:refresh": "node bin/migrate.js refresh"
  },
  "dependencies": {
    "alasql": "^4.6.6",
    "circular-json-es6": "^2.0.2",
    "commander": "^12.1.0",
    "express": "^4.21.1",
    "graphql-http": "^1.22.0",
    "graphql": "^16.8.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.14.0",
    "ws": "^8.16.0",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "socket.io": "^4.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "prom-client": "^15.1.0",
    "consul": "^1.2.0",
    "etcd3": "^1.1.0",
    "ioredis": "^5.6.1",
    "isomorphic-dompurify": "^2.25.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.13.1",
    "redis": "^5.5.6",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.5.4",
    "thenby": "^1.3.4",
    "why-is-node-running": "^3.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "bcrypt": "^5.1.0",
    "rimraf": "^5.0.0",
    "supertest": "^7.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "socket.io-client": "^4.7.0"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/api.d.ts",
      "import": "./lib/api.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./plugins/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./types/index.js"
    },
    "./decorators": {
      "types": "./dist/lib/decorators.d.ts",
      "import": "./lib/decorators.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./client/index.js"
    }
  }
}
